# Copy to .env.local for running `npm run dev` outside Docker.
# When running via docker compose, this is injected as an environment variable instead.
API_INTERNAL_URL=http://localhost:8000
# Browser-visible: the address the browser itself can reach the API's
# WebSocket endpoint at directly (see app/api/ws.py). Same host/port as
# API_INTERNAL_URL above when running outside Docker.
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000
