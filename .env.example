# Copy this file to .env before running `docker compose up`.
# .env is git-ignored — these are dev-only defaults, never real secrets.

# --- Postgres ---
POSTGRES_USER=wrkbase
POSTGRES_PASSWORD=wrkbase_dev_password
POSTGRES_DB=wrkbase
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API ---
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
