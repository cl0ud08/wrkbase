# Copy this file to .env before running `docker compose up`.
# .env is git-ignored — these are dev-only defaults, never real secrets.

# --- Postgres ---
# Superuser, used only to run migrations (needs CREATE ROLE / CREATE POLICY /
# ALTER TABLE privileges). The running API never connects with this user.
POSTGRES_USER=wrkbase
POSTGRES_PASSWORD=wrkbase_dev_password
POSTGRES_DB=wrkbase
POSTGRES_PORT=5432

# Least-privilege role the API actually connects as. Not a superuser and not
# the table owner, so Postgres RLS applies to it with no extra flags needed.
APP_DB_USER=wrkbase_app
APP_DB_PASSWORD=wrkbase_app_dev_password

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
# Not the guest/guest default: RabbitMQ blocks that account from connecting
# over anything but localhost, which the worker/api containers never are to
# each other on the docker network. One real user is enough here — unlike
# Postgres's superuser/wrkbase_app split, there's no per-tenant boundary for
# RabbitMQ itself to enforce; tenant isolation for a queued job is entirely
# the consumer's responsibility (see apps/api/worker/main.py), not something
# the broker is asked to know about.
RABBITMQ_USER=wrkbase
RABBITMQ_PASSWORD=wrkbase_mq_dev_password
RABBITMQ_PORT=5672
# Management UI (http://localhost:15672) — genuinely optional, useful for
# watching queue depth / unacked counts by hand during local dev.
RABBITMQ_MANAGEMENT_PORT=15672

# --- API ---
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
# Used to build the shareable link returned by POST /invites — the API
# container reaches the frontend over the docker network, but a human
# clicking the link needs the browser-facing address, hence a separate var
# from API_INTERNAL_URL below.
FRONTEND_URL=http://localhost:3000

# Generate your own: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=replace-with-a-real-random-secret

# --- AI (Phase 3) ---
# Left empty on purpose — this file is committed, .env is not. Get your own:
# Groq: https://console.groq.com/keys · Gemini: https://aistudio.google.com/apikey
# Neither is called yet in this slice (ticket-triage plumbing only, no real
# LLM call) — added now so the config surface exists before the next slice
# needs it, not because anything reads them today.
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Web ---
WEB_PORT=3000
